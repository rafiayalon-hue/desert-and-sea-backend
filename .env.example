# Database
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/desert_and_sea

# Redis (for Celery task queue)
REDIS_URL=redis://localhost:6379/0

# MiniHotel API
MINIHOTEL_API_KEY=your_minihotel_api_key
